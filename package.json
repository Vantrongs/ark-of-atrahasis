{
  "name": "ark-of-atrahasis",
  "version": "0.3.1",
  "description": "Safe DOM wrapper made for the usage in Secure ECMAScript compartments",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "sandbox",
    "dom",
    "javascript",
    "wrapper",
    "typescript",
    "frontend",
    "ses",
    "bluearchive",
    "cute-and-funny",
    "hardened-js",
    "ark-of-atrahasis"
  ],
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
