{
  "name": "ark-of-atrahasis",
  "version": "0.3.1",
  "description": "Capability-oriented DOM wrapper for Secure ECMAScript integrations",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "npm-shrinkwrap.json",
    "scripts",
    "src",
    "test",
    "tsconfig.json",
    "tsup.config.ts",
    "RELEASING.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json && node node_modules/typescript-current/bin/tsc --noEmit -p tsconfig.json",
    "lint": "biome lint src test scripts tsup.config.ts",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:package": "node scripts/test-package.mjs",
    "pack:verified": "node scripts/test-package.mjs --output .artifacts",
    "audit": "npm audit --audit-level=low",
    "check": "npm run lint && npm run typecheck && npm test && npm run audit && npm run test:package",
    "prepack": "npm run build",
    "prepublishOnly": "node scripts/reject-direct-publish.mjs"
  },
  "keywords": [
    "sandbox",
    "dom",
    "javascript",
    "wrapper",
    "typescript",
    "frontend",
    "ses",
    "bluearchive",
    "cute-and-funny",
    "hardened-js",
    "ark-of-atrahasis"
  ],
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notwindstone/ark-of-atrahasis.git"
  },
  "homepage": "https://github.com/notwindstone/ark-of-atrahasis#readme",
  "bugs": {
    "url": "https://github.com/notwindstone/ark-of-atrahasis/issues"
  },
  "packageManager": "npm@11.18.0",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-current": "npm:typescript@7.0.2",
    "typescript-min": "npm:typescript@5.0.4"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}
