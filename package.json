{
  "name": "ark-of-atrahasis",
  "version": "0.3.1",
  "description": "Capability-oriented DOM wrapper for Secure ECMAScript integrations",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "tsup.config.ts",
    "RELEASING.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint src test scripts tsup.config.ts",
    "test:unit": "vitest run",
    "test:api": "npm run build && node --test test/api.node.mjs",
    "test": "npm run test:unit && npm run test:api",
    "test:package": "node scripts/test-package.mjs",
    "pack:verified": "node scripts/test-package.mjs --output .artifacts",
    "check": "npm run lint && npm run typecheck && npm test && npm run test:package",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "sandbox",
    "dom",
    "javascript",
    "wrapper",
    "typescript",
    "frontend",
    "ses",
    "bluearchive",
    "cute-and-funny",
    "hardened-js",
    "ark-of-atrahasis"
  ],
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notwindstone/ark-of-atrahasis.git"
  },
  "homepage": "https://github.com/notwindstone/ark-of-atrahasis#readme",
  "bugs": {
    "url": "https://github.com/notwindstone/ark-of-atrahasis/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.9.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/jsdom": "21.1.7",
    "jsdom": "26.1.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "3.2.4"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}
